   ],
   "source": [
    "def is_prime(num):\n",
    "    if num <= 1:\n",
    "        return False\n",
    "    \n",
    "    for i in range(2, num):\n",
    "        if num % i == 0:\n",
    "            return False\n",
    "    return True\n",
    "\n",
    "# Test cases\n",
    "print(\"Is 7 prime?\", is_prime(7))\n",
    "print(\"Is 10 prime?\", is_prime(10))"
   ]
  }
 ],
